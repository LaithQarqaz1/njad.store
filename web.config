<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- Redirect all HTTP requests to HTTPS -->
        <rule name="HTTP to HTTPS redirect" stopProcessing="true">
          <match url="(.*)" ignoreCase="true" />
          <conditions>
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- Canonical host: force apex domain njad.store (avoid www) -->
        <rule name="Force apex host" stopProcessing="true">
          <match url="(.*)" ignoreCase="true" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTPS}" pattern="on" ignoreCase="true" />
            <add input="{HTTP_HOST}" pattern="^www\.njad\.store$" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://njad.store/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- Legacy deposit page path -> inline route in index -->
        <rule name="Legacy deposit redirect" stopProcessing="true">
          <match url="^edaa\.html$" ignoreCase="true" />
          <action type="Redirect" url="/index.html#/deposit" redirectType="Permanent" />
        </rule>

        <!-- Firebase Auth helper paths must be served before the SPA fallback. -->
        <rule name="Firebase auth handler helper" stopProcessing="true">
          <match url="^__/auth/handler/?$" ignoreCase="true" />
          <action type="Rewrite" url="/__/auth/handler/index.html" />
        </rule>
        <rule name="Firebase auth iframe helper" stopProcessing="true">
          <match url="^__/auth/iframe/?$" ignoreCase="true" />
          <action type="Rewrite" url="/__/auth/iframe/index.html" />
        </rule>
        <rule name="Firebase auth links helper" stopProcessing="true">
          <match url="^__/auth/links/?$" ignoreCase="true" />
          <action type="Rewrite" url="/__/auth/links.html" />
        </rule>

        <!-- SPA fallback: let index.html handle client-side routes like /login and /404 -->
        <rule name="SPA rewrite" stopProcessing="true">
          <match url=".*" ignoreCase="true" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>
    <staticContent>
      <remove fileExtension="." />
      <mimeMap fileExtension="." mimeType="text/html" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
    </staticContent>
    <httpProtocol>
      <customHeaders>
        <!-- HSTS: force HTTPS in browsers for one year -->
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains; preload" />
        <!-- Stop MIME-sniffing (content-type confusion / drive-by script execution). -->
        <add name="X-Content-Type-Options" value="nosniff" />
        <!-- Clickjacking: only this site may frame its own pages (legacy fallback for old browsers). -->
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <!-- Don't leak full URLs (ids/tokens) to third-party origins. -->
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <!-- Disable powerful features the storefront never uses. -->
        <add name="Permissions-Policy" value="geolocation=(), camera=(), microphone=(), usb=()" />
        <!--
          Content-Security-Policy. script-src/style-src/connect-src are kept
          permissive (https:, 'unsafe-inline', 'unsafe-eval') so Firebase, the
          CDN libraries and the existing eval()/new Function() usage keep working
          on this large app — but the high-value, zero-breakage directives are
          locked down:
            object-src 'none'      -> blocks <object>/<embed>/Flash XSS vectors
            base-uri 'self'        -> blocks <base> tag hijacking of relative URLs
            frame-ancestors 'self' -> modern clickjacking protection
          Tightening script-src to an explicit origin allow-list is a safe
          follow-up once an inline-handler audit is done.
        -->
        <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https: wss:; frame-src 'self' https:; media-src 'self' https: data: blob:; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'self'; upgrade-insecure-requests" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
  <location path="index.html">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="DisableCache" />
      </staticContent>
    </system.webServer>
  </location>
  <location path="sw.js">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="DisableCache" />
      </staticContent>
    </system.webServer>
  </location>
  <location path="header.css">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="30.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>
  <location path="site-bundle.js">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="30.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>
  <location path="site-bundle.css">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="30.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>
  <location path="site_settings.js">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="DisableCache" />
      </staticContent>
    </system.webServer>
  </location>
  <location path="header.js">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="30.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>
</configuration>
